# Viral Clip Studio — Environment Variables
# Copy this to .env and fill in real values.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/viral_clip_studio

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0

# --- API Keys (Phase 1 scrapers) ---
NEWSAPI_KEY=
YOUTUBE_API_KEY=
GDELT_API_KEY=

# --- API Keys (Phase 2+ providers) ---
DEEPSEEK_API_KEY=
CREATOMATE_API_KEY=
ELEVENLABS_API_KEY=
HEYGEN_API_KEY=

# --- OAuth (Phase 3) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# --- Storage ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# --- App ---
SECRET_KEY=change-me-to-a-random-string
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
